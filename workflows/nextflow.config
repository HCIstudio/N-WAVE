profiles {
  docker {
    process.executor  = 'local'
    docker.enabled    = true
    process.container = 'ubuntu:22.04'
    process.shell     = ['/usr/bin/env','bash','-ueo','pipefail']
  }
}

/* All work/output live under the shared named volume path */
workDir       = '/shared/work'
params.outdir = '/shared/data'

/* No docker.runOptions needed now — dind mounts /shared itself */

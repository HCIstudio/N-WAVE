# Example environment for the from-source Docker Compose build (docker-compose.yml).
# Copy to `.env` and adjust as needed. These values are read by Docker Compose
# for variable substitution and by the backend at runtime.
#
# To run the prebuilt published images instead, use `latest.yml` — it is
# self-contained and needs no .env.

# --- Backend / database ---
PORT=5001
MONGODB_URI=mongodb://mongodb:27017/nwave
# Comma-separated list of origins allowed to call the API.
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost

# --- Frontend build metadata (stamped into the UI footer) ---
# Usually left blank locally; the frontend derives them from git when unset.
APP_VERSION=
BUILD_DATE=
GIT_SHA=
